   },
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv('https://raw.githubusercontent.com/opengeoshub/vopendata/main/csv/housing.csv')\n",
    "resolution = 10\n",
    "df = df.dggrid.latlon2dggrid(dggrid_instance, dggs_type, resolution, lat_col='lat', lon_col='lon', address_type=address_type)\n",
    "df"
   ]
