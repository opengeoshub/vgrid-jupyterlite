  {
   "cell_type": "markdown",
   "metadata": {
   },
   "source": [
    "### DGGRID setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "executionInfo": {
     "elapsed": 2251,
     "status": "ok",
     "timestamp": 1779604500224,
     "user": {
      "displayName": "",
      "userId": ""
     },
     "user_tz": -420
    },
   },
   "outputs": [],
   "source": [
    "from dggrid4py import tool, DGGRIDv8\n",
    "\n",
    "dggrid_exec = tool.get_portable_executable('.')\n",
    "\n",
    "dggrid_instance = DGGRIDv8(\n",
    "    executable=dggrid_exec,\n",
    "    working_dir='.',\n",
    "    capture_logs=False,\n",
    "    silent=True,\n",
    "    has_gdal=False,\n",
    "    tmp_geo_out_legacy=True,\n",
    "    debug=False,\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
   },
   "source": [
    "### Import dggridpandas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "executionInfo": {
     "elapsed": 1249,
     "status": "ok",
     "timestamp": 1779604503708,
     "user": {
      "displayName": "",
      "userId": ""
     },
     "user_tz": -420
    },
   },
   "outputs": [],
   "source": [
    "from vgridpandas import dggridpandas\n",
    "dggs_type = \"ISEA3H\"\n",
    "address_type = \"SEQNUM\""
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
   },
   "source": [
